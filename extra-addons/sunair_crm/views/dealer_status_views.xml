<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_dealer_status_list" model="ir.ui.view">
        <field name="name">dealer.status.list</field>
        <field name="model">dealer.status</field>
        <field name="arch" type="xml">
            <list string="Dealer Statuses" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="color" widget="color_picker"/>
                <field name="fold"/>
            </list>
        </field>
    </record>

    <record id="view_dealer_status_form" model="ir.ui.view">
        <field name="name">dealer.status.form</field>
        <field name="model">dealer.status</field>
        <field name="arch" type="xml">
            <form string="Dealer Status">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                        <group>
                            <field name="fold"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dealer_status" model="ir.actions.act_window">
        <field name="name">Dealer Statuses</field>
        <field name="res_model">dealer.status</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_dealer_status"
              name="Dealer Statuses"
              parent="sunair_crm.menu_dealer_configuration"
              action="action_dealer_status"
              sequence="30"/>

</odoo>
