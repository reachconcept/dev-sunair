<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_dealer_request_state_list" model="ir.ui.view">
        <field name="name">dealer.request.state.list</field>
        <field name="model">dealer.request.state</field>
        <field name="arch" type="xml">
            <list string="Dealer Request States" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="is_closed"/>
                <field name="fold"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_dealer_request_state_form" model="ir.ui.view">
        <field name="name">dealer.request.state.form</field>
        <field name="model">dealer.request.state</field>
        <field name="arch" type="xml">
            <form string="Dealer Request State">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                        <group>
                            <field name="fold"/>
                            <field name="is_closed"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_dealer_request_state" model="ir.actions.act_window">
        <field name="name">Request States</field>
        <field name="res_model">dealer.request.state</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Configuration parent menu under Dealers -->
    <menuitem id="menu_dealer_configuration"
              name="Configuration"
              parent="sunair_crm.menu_dealer_application_root"
              sequence="100"/>

    <!-- Request States under Configuration -->
    <menuitem id="menu_dealer_request_state"
              name="Request States"
              parent="menu_dealer_configuration"
              action="action_dealer_request_state"
              sequence="10"/>

</odoo>
