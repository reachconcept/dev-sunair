<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_crm_territory_list" model="ir.ui.view">
        <field name="name">crm.territory.list</field>
        <field name="model">crm.territory</field>
        <field name="arch" type="xml">
            <list string="Territories">
                <field name="name"/>
                <field name="code"/>
                <field name="team_id"/>
                <field name="backup_user_id" optional="hide"/>
                <field name="company_id"/>
                <field name="zip_range" optional="hide"/>
                <field name="auto_assign" optional="hide"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_crm_territory_form" model="ir.ui.view">
        <field name="name">crm.territory.form</field>
        <field name="model">crm.territory</field>
        <field name="arch" type="xml">
            <form string="Territory">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object"
                            name="action_view_leads"
                            class="oe_stat_button"
                            icon="fa-filter">
                        <field name="lead_count" widget="statinfo" string="Leads"/>
                    </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Enter Territory Name"/>
                        </h1>
                    </div>
                    <group col="2">
                        <group string="General Information">
                            <field name="code"/>
                            <field name="team_id"/>
                            <field name="backup_user_id" readonly="1"/>
                        </group>
                        <group string="Configuration">
                            <field name="company_id"/>
                            <field name="zip_range" placeholder="Eg:- 100-200"/>
                            <field name="auto_assign"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_crm_territory" model="ir.actions.act_window">
        <field name="name">Territories</field>
        <field name="res_model">crm.territory</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_crm_territory"
              name="Territories"
              parent="crm.crm_menu_config"
              action="action_crm_territory"
              sequence="60"/>

</odoo>