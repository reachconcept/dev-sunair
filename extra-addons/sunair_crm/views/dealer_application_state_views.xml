<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_dealer_application_state_list" model="ir.ui.view">
        <field name="name">dealer.application.state.list</field>
        <field name="model">dealer.application.state</field>
        <field name="arch" type="xml">
            <list string="Application States" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="state_type"/>
                <field name="is_closed"/>
                <field name="fold"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <record id="view_dealer_application_state_form" model="ir.ui.view">
        <field name="name">dealer.application.state.form</field>
        <field name="model">dealer.application.state</field>
        <field name="arch" type="xml">
            <form string="Application State">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="state_type"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                        <group>
                            <field name="fold"/>
                            <field name="is_closed"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dealer_application_state" model="ir.actions.act_window">
        <field name="name">Application States</field>
        <field name="res_model">dealer.application.state</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_dealer_application_state"
              name="Application States"
              parent="sunair_crm.menu_dealer_configuration"
              action="action_dealer_application_state"
              sequence="20"/>

</odoo>
