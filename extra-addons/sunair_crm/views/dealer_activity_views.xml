<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_dealer_activity_list" model="ir.ui.view">
        <field name="name">dealer.activity.list</field>
        <field name="model">dealer.activity</field>
        <field name="arch" type="xml">
            <list string="Dealer Activities" decoration-success="state == 'done'" decoration-muted="state == 'cancelled'">
                <field name="date"/>
                <field name="subject"/>
                <field name="partner_id"/>
                <field name="contact_method"/>
                <field name="user_id"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-warning="state == 'planned'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_dealer_activity_form" model="ir.ui.view">
        <field name="name">dealer.activity.form</field>
        <field name="model">dealer.activity</field>
        <field name="arch" type="xml">
            <form string="Dealer Activity">
                <header>
                    <button name="action_mark_done" type="object" string="Mark as Done"
                            class="btn-primary" invisible="state == 'done'"/>
                    <button name="action_reset_planned" type="object" string="Reset to Planned"
                            invisible="state == 'planned'"/>
                    <button name="action_mark_cancelled" type="object" string="Cancel"
                            invisible="state == 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="planned,done,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="subject"/>
                        <h1><field name="subject" placeholder="e.g. Follow-up call with dealer"/></h1>
                    </div>
                    <group>
                        <group string="Activity Details">
                            <field name="partner_id" options="{'no_create': True}"/>
                            <field name="contact_method"/>
                            <field name="date"/>
                            <field name="user_id" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_dealer_activity_kanban" model="ir.ui.view">
        <field name="name">dealer.activity.kanban</field>
        <field name="model">dealer.activity</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="subject"/>
                <field name="partner_id"/>
                <field name="contact_method"/>
                <field name="date"/>
                <field name="user_id"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="subject"/>
                                    </strong>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div><field name="partner_id"/></div>
                                <div class="mt-1">
                                    <span class="badge rounded-pill bg-secondary text-white">
                                        <field name="contact_method"/>
                                    </span>
                                </div>
                                <div class="text-muted mt-1">
                                    <field name="date"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left"/>
                                <div class="oe_kanban_bottom_right">
                                    <field name="user_id" widget="many2one_avatar_user"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Action -->
    <record id="action_dealer_activity" model="ir.actions.act_window">
        <field name="name">Dealer Activities</field>
        <field name="res_model">dealer.activity</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

    <!-- Menu under Dealers -->
    <menuitem id="menu_dealer_activity"
              name="Activities"
              parent="sunair_crm.menu_crm_application_root"
              action="action_dealer_activity"
              sequence="2"/>

</odoo>
