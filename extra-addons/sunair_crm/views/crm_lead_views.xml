<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_lead_kanban_inherit_territory" model="ir.ui.view">
    <field name="name">crm.lead.kanban.inherit.territory</field>
    <field name="model">crm.lead</field>
    <field name="inherit_id" ref="crm.crm_case_kanban_view_leads"/>
    <field name="arch" type="xml">
        <xpath expr="//kanban" position="inside">
            <field name="customer_type_id"/>
            <field name="territory_id"/>
        </xpath>
        <xpath expr="//field[@name='tag_ids']" position="after">
            <t t-if="record.customer_type_id.raw_value">
                <div class="mt-1">
                    <span class="badge rounded-pill bg-info text-white">
                        <t t-esc="record.customer_type_id.value"/>
                    </span>
                </div>
            </t>
            <!-- <t t-if="record.lead_type_id.raw_value">
                <div class="mt-1">
                    <span class="badge rounded-pill bg-secondary text-white">
                        <t t-esc="record.lead_type_id.value"/>
                    </span>
                </div>
            </t> -->
            <t t-if="record.territory_id.raw_value">
                <div class="mt-1">
                    <span class="badge rounded-pill bg-primary text-white">
                        <t t-esc="record.territory_id.value"/>
                    </span>
                </div>
            </t>
        </xpath>
    </field>
</record>

    <record id="view_crm_lead_form_inherit_territory" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.territory</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <!-- <xpath expr="//header" position="inside">
                <button name="action_create_application"
                        type="object"
                        string="Create Dealer Application"
                        class="btn-primary"
                        invisible="type == 'lead' or not is_dealer_pipeline or application_count != 0"/>
            </xpath> -->

            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_applications"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-file-text"
                        invisible="application_count == 0">
                    <field name="application_count" widget="statinfo" string="Applications"/>
                </button>
            </xpath>

            <xpath expr="//header" position="inside">
                <button name="action_open_dealer_match_wizard"
                        type="object"
                        string="Find Best Dealer"
                        class="btn-secondary"
                        invisible="dealer_id != False"/>
            </xpath>

            <!-- Filter stage_id to exclude dealer-only stages in regular CRM -->
            <xpath expr="//field[@name='stage_id']" position="attributes">
                <attribute name="domain">[('pipeline_type', 'in', ['all', 'regular'])]</attribute>
            </xpath>

            <xpath expr="//group[@name='lead_partner']//field[@name='partner_id']" position="after">
                <field name="customer_type_id" options="{'no_create': True}"/>
                <field name="lead_type_id" options="{'no_create': True}"/>
            </xpath>
            <xpath expr="//group[@name='opportunity_partner']/field[@name='partner_id']" position="attributes">
                <attribute name="string">Customer</attribute>
            </xpath>
            <xpath expr="//group[@name='opportunity_partner']/field[@name='partner_id']" position="after">
                <field name="customer_type_id" options="{'no_create': True}"/>
                <field name="lead_type_id" options="{'no_create': True}"/>
                <field name="partner_name"/>
                <label for="street_page_lead" string="Address"/>
                <div class="o_address_format">
                    <field name="street" id="street_page_lead" placeholder="Street..." class="o_address_street"/>
                    <field name="street2" placeholder="Street 2..." class="o_address_street"/>
                    <field name="city" placeholder="City" class="o_address_city"/>
                    <field name="state_id" class="o_address_state" placeholder="State" options="{&quot;no_open&quot;: True}"/>
                    <field name="zip" placeholder="ZIP" class="o_address_zip"/>
                    <field name="country_id" placeholder="Country" class="o_address_country" options="{&quot;no_open&quot;: True, &quot;no_create&quot;: True}"/>
                </div>
                <field name="lang_active_count" invisible="1"/>
                <field name="lang_id" invisible="lang_active_count &lt;= 1" options="{'no_quick_create': True, 'no_create_edit': True, 'no_open': True}"/>
            </xpath>
            <xpath expr="//field[@name='tag_ids']" position="after">
                <field name="territory_id" readonly="1"/>
                <field name="allowed_tag_ids" invisible="1"/>
                <field name="crm_product_category_id"/>
                <field name="dealer_id" options="{'no_create': True}"/>
            </xpath>

        </field>
    </record>

    <record id="action_crm_lead" model="ir.actions.act_window">
        <field name="name">Leads</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">list,kanban,form,pivot,calendar</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>

    <menuitem id="menu_crm_territory_leads"
              name="Leads"
              parent="crm.crm_menu_root"
              action="action_crm_lead"
              sequence="1"/>

</odoo>