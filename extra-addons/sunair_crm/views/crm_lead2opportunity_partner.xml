<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_crm_lead2opportunity_partner_inherit" model="ir.ui.view">
        <field name="name">crm.lead2opportunity.partner.inherit</field>
        <field name="model">crm.lead2opportunity.partner</field>
        <field name="inherit_id" ref="crm.view_crm_lead2opportunity_partner"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='name']" position="after">
                <group string="Extra Info">
                    <field name="customer_type_id"/>
                    <field name="lead_type_id"/>
                    <field name="territory_id" readonly="1"/>
                </group>
            </xpath>

        </field>
    </record>

</odoo>
