    <record id="res_partner_kanban_inherit_dealer" model="ir.ui.view">
        <field name="name">res.partner.kanban.inherit.dealer</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.res_partner_kanban_view"/>
        <field name="arch" type="xml">

            <xpath expr="//kanban" position="inside">
                <field name="is_dealer"/>
            </xpath>

            <!-- YOUR BADGE -->
            <xpath expr="//t[@t-name='card']" position="inside">
                <t t-if="record.is_dealer and record.is_dealer.raw_value">
                    <div class="position-absolute top-0 end-0 m-1">
                        <span class="badge bg-success">Dealer</span>
                    </div>
                </t>
            </xpath>

        </field>
    </record>

    <!-- Dedicated dealer kanban view -->
    <record id="view_dealer_partner_kanban" model="ir.ui.view">
        <field name="name">res.partner.dealer.kanban</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column">
                <field name="name"/>
                <field name="is_company"/>
                <field name="street"/>
                <field name="city"/>
                <field name="state_id"/>
                <field name="phone"/>

                <field name="email"/>
                <field name="website"/>
                <field name="user_id"/>
                <field name="category_id"/>
                <field name="dealer_status_id"/>
                <field name="dealer_status_color"/>
                <field name="territory_id"/>
                <field name="dealer_representative_id"/>
                <field name="activity_ids"/>
                <field name="activity_state"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click" style="padding: 0;">

                            <!-- Green dealer bar -->
                            <div style="height: 4px; border-radius: 4px 4px 0 0; background: #20c997;"/>

                            <div style="padding: 10px 12px 12px 12px;">

                                <!-- Header: dealer badge + status + activity -->
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <div class="d-flex gap-1 align-items-center">
                                        <span class="badge rounded-pill"
                                              style="background:#20c99722; color:#198754; border:1px solid #20c99755;">
                                            <i class="fa fa-star me-1"/>Dealer
                                        </span>
                                        <t t-if="record.dealer_status_id.raw_value">
                                            <span class="badge rounded-pill"
                                                  t-attf-style="
                                                    background: #{
                                                        record.dealer_status_color.raw_value == 1  ? '#f1948a' :
                                                        record.dealer_status_color.raw_value == 2  ? '#f0a500' :
                                                        record.dealer_status_color.raw_value == 3  ? '#f7dc6f' :
                                                        record.dealer_status_color.raw_value == 4  ? '#00a09d' :
                                                        record.dealer_status_color.raw_value == 5  ? '#814968' :
                                                        record.dealer_status_color.raw_value == 6  ? '#e2a272' :
                                                        record.dealer_status_color.raw_value == 7  ? '#2980b9' :
                                                        record.dealer_status_color.raw_value == 8  ? '#a29f97' :
                                                        record.dealer_status_color.raw_value == 9  ? '#d6145f' :
                                                        record.dealer_status_color.raw_value == 10 ? '#2ecc71' :
                                                        record.dealer_status_color.raw_value == 11 ? '#8e44ad' :
                                                                                                     '#adb5bd'
                                                    }; color: black;">
                                                <t t-esc="record.dealer_status_id.value"/>
                                            </span>
                                        </t>
                                    </div>
                                    <field name="activity_ids" widget="activity"/>
                                </div>

                                <!-- Name -->
                                <div class="fw-bold mb-0" style="line-height: 1.3;">
                                    <t t-if="record.is_company.raw_value">
                                        <i class="fa fa-building-o me-1 text-muted"/>
                                    </t>
                                    <t t-else="">
                                        <i class="fa fa-user me-1 text-muted"/>
                                    </t>
                                    <t t-esc="record.name.value"/>
                                </div>

                                <!-- Location -->
                                <t t-if="record.city.raw_value or record.state_id.raw_value">
                                    <div class="text-muted mb-1 mt-1">
                                        <i class="fa fa-map-marker me-1"/>
                                        <t t-if="record.city.raw_value"><t t-esc="record.city.value"/></t>
                                        <t t-if="record.city.raw_value and record.state_id.raw_value">, </t>
                                        <t t-if="record.state_id.raw_value"><t t-esc="record.state_id.value"/></t>
                                    </div>
                                </t>

                                <!-- Phone -->
                                <t t-if="record.phone.raw_value or record.mobile.raw_value">
                                    <div class="text-muted mb-1">
                                        <i class="fa fa-phone me-1"/>
                                        <t t-esc="record.phone.value"/>
                                    </div>
                                </t>

                                <!-- Email -->
                                <t t-if="record.email.raw_value">
                                    <div class="text-muted mb-1" style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                        <i class="fa fa-envelope-o me-1"/>
                                        <t t-esc="record.email.value"/>
                                    </div>
                                </t>

                                <!-- Website -->
                                <t t-if="record.website.raw_value">
                                    <div class="text-muted mb-2" style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                        <i class="fa fa-globe me-1"/>
                                        <t t-esc="record.website.value"/>
                                    </div>
                                </t>

                                <!-- Tags -->
                                <t t-if="record.category_id.raw_value">
                                    <div class="d-flex flex-wrap gap-1 mb-2">
                                        <field name="category_id" widget="many2many_tags"
                                               options="{'color_field': 'color'}"/>
                                    </div>
                                </t>

                                <!-- Territory -->
                                <t t-if="record.territory_id.raw_value">
                                    <div class="text-muted mb-2">
                                        <i class="fa fa-map me-1"/>
                                        <t t-esc="record.territory_id.value"/>
                                    </div>
                                </t>

                                <!-- Divider -->
                                <hr style="margin: 8px 0; border-color: #e9ecef;"/>

                                <!-- Footer: labeled user pills -->
                                <div class="d-flex flex-wrap gap-2">
                                    <t t-if="record.user_id.raw_value">
                                        <div class="d-flex align-items-center gap-1"
                                             style="background:#f8f9fa; border:1px solid #dee2e6; border-radius:20px; padding: 2px 8px 2px 2px;">
                                            <field name="user_id" widget="many2one_avatar_user"/>
                                            <small class="text-muted" style="white-space:nowrap;">Salesperson</small>
                                        </div>
                                    </t>
                                    <t t-if="record.dealer_representative_id.raw_value">
                                        <div class="d-flex align-items-center gap-1"
                                             style="background:#f8f9fa; border:1px solid #dee2e6; border-radius:20px; padding: 2px 8px 2px 2px;">
                                            <field name="dealer_representative_id" widget="many2one_avatar_user"/>
                                            <small class="text-muted" style="white-space:nowrap;">Rep</small>
                                        </div>
                                    </t>
                                </div>

                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_dealer_partner_search" model="ir.ui.view">
        <field name="name">res.partner.dealer.search</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <search string="Dealers">
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="dealer_representative_id"/>
                <field name="territory_id"/>
                <field name="dealer_status_id"/>
                <filter name="my_dealers" string="My Dealers"
                        domain="[('dealer_representative_id', '=', uid)]"/>
                <separator/>
                <filter name="no_rep" string="No Representative"
                        domain="[('dealer_representative_id', '=', False)]"/>
                <!-- <group expand="0" string="Group By">
                    <filter name="group_by_status" string="Dealer Status"
                            context="{'group_by': 'dealer_status_id'}"/>
                    <filter name="group_by_territory" string="Territory"
                            context="{'group_by': 'territory_id'}"/>
                    <filter name="group_by_rep" string="Representative"
                            context="{'group_by': 'dealer_representative_id'}"/>
                </group> -->
            </search>
        </field>
    </record>

    <record id="action_dealers" model="ir.actions.act_window">
        <field name="name">Dealers</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('is_dealer', '=', True)]</field>
        <field name="search_view_id" ref="view_dealer_partner_search"/>
        <field name="context">{'default_is_dealer': True, 'search_default_my_dealers': 1}</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('view_dealer_partner_kanban')}),
        ]"/>
        <field name="context">{'default_is_dealer': True, 'search_default_my_dealers': 1}</field>
    </record>

    <menuitem id="menu_dealers"
              name="Dealers"
              parent="sunair_crm.menu_dealer_application_root"
              action="action_dealers"
              sequence="1"/>

    <!-- Inherit partner form to add Dealer Info section -->
    <record id="view_partner_form_inherit_dealer" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.dealer</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <!-- Dealer smart button in the button box -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button"
                        name="%(sunair_crm.action_dealers)d"
                        type="action"
                        icon="fa-star"
                        invisible="not is_dealer">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Dealer</span>
                    </div>
                </button>
            </xpath>

            <!-- Dealer Info tab appended after existing tabs -->
            <xpath expr="//notebook" position="inside">
                <page string="Dealer Info" invisible="not is_dealer">
                    <group string="Dealer Status">
                        <group>
                            <field name="is_dealer" widget="boolean_toggle"/>
                            <field name="dealer_status_id" options="{'no_create': True}"/>
                            <field name="territory_id" options="{'no_create': True}"/>
                            <field name="dealer_representative_id" widget="many2one_avatar_user"/>
                        </group>
                    </group>
                    <group string="Product Lines">
                        <field name="product_line_ids" nolabel="1" invisible="not is_dealer">
                            <list editable="bottom">
                                <field name="product_line_id" options="{'no_create': False}"/>
                                <field name="notes"/>
                                <field name="active" column_invisible="True"/>
                            </list>
                        </field>
                    </group>
                </page>
            </xpath>

            <!-- Also show is_dealer toggle and territory on the main form
                 when the partner is not yet a dealer (so it can be set) -->
            <xpath expr="//field[@name='lang']" position="after">
                <field name="is_dealer" widget="boolean_toggle"/>
                <field name="dealer_status_id"
                       options="{'no_create': True}"
                       invisible="not is_dealer"/>
                <field name="territory_id"
                       options="{'no_create': True}"
                       invisible="not is_dealer"/>
                <field name="dealer_representative_id"
                       widget="many2one_avatar_user"
                       invisible="not is_dealer"/>
            </xpath>

        </field>
    </record>

</odoo>
