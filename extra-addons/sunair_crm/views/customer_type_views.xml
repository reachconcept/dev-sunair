<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_customer_type_list" model="ir.ui.view">
        <field name="name">customer.type.list</field>
        <field name="model">customer.type</field>
        <field name="arch" type="xml">
            <list string="Customer Types" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="tag_ids" widget="many2many_tags"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_customer_type_form" model="ir.ui.view">
        <field name="name">customer.type.form</field>
        <field name="model">customer.type</field>
        <field name="arch" type="xml">
            <form string="Customer Type">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="tag_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_customer_type" model="ir.actions.act_window">
        <field name="name">Customer Types</field>
        <field name="res_model">customer.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_type"
              name="Types"
              parent="crm.crm_menu_config"
              sequence="50"/>

    <menuitem id="menu_customer_type"
              name="Customer Types"
              parent="sunair_crm.menu_type"
              action="action_customer_type"
              sequence="10"/>
</odoo>