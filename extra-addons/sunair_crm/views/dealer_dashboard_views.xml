<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_dealer_dashboard_kanban" model="ir.ui.view">
    <field name="name">dealer.dashboard.kanban</field>
    <field name="model">dealer.dashboard</field>
    <field name="arch" type="xml">
        <kanban create="0" delete="0" class="o_kanban_dashboard">

            <templates>

                <t t-name="card">
                    <div class="o_kanban_card p-3 shadow rounded bg-white">

                        <!-- TITLE -->
                        <div class="fw-bold fs-4 mb-3">
                            Dealer Dashboard
                        </div>

                        <!-- KPI ROW -->
                        <div class="row text-center mb-3">

                            <div class="col-3">
                                <div class="p-2 bg-primary text-white rounded">
                                    <div class="fs-5">
                                        <field name="total_leads"/>
                                    </div>
                                    <small>Leads</small>
                                </div>
                            </div>

                            <div class="col-3">
                                <div class="p-2 bg-success text-white rounded">
                                    <div class="fs-5">
                                        <field name="my_applications"/>
                                    </div>
                                    <small>Applications</small>
                                </div>
                            </div>

                            <div class="col-3">
                                <div class="p-2 bg-warning text-dark rounded">
                                    <div class="fs-5">
                                        <field name="pipeline_leads"/>
                                    </div>
                                    <small>Pipeline</small>
                                </div>
                            </div>

                            <div class="col-3">
                                <div class="p-2 bg-info text-white rounded">
                                    <div class="fs-5">
                                        <field name="won_leads"/>
                                    </div>
                                    <small>Won</small>
                                </div>
                            </div>

                        </div>

                        <!-- BUTTONS -->
                        <div class="row mb-3">

                            <div class="col-3">
                                <button type="object" name="action_view_leads" class="btn btn-primary w-100">
                                    Leads
                                </button>
                            </div>

                            <div class="col-3">
                                <button type="object" name="action_view_applications" class="btn btn-success w-100">
                                    Applications
                                </button>
                            </div>

                            <div class="col-3">
                                <button type="object" name="action_view_pipeline" class="btn btn-warning w-100">
                                    Pipeline
                                </button>
                            </div>

                            <div class="col-3">
                                <button type="object" name="action_view_won" class="btn btn-info w-100">
                                    Won
                                </button>
                            </div>

                        </div>

                        <!-- GRAPH -->
                        <div>
                            <field name="dashboard_graph_data" widget="dashboard_graph"
                                   t-att-graph_type="'bar'"/>
                        </div>

                    </div>
                </t>

            </templates>

        </kanban>
    </field>
</record>

<record id="action_dealer_dashboard" model="ir.actions.act_window">
    <field name="name">Dealer Dashboard</field>
    <field name="res_model">dealer.dashboard</field>
    <field name="view_mode">kanban</field>
</record>

<menuitem id="menu_dealer_dashboard"
          name="Dealer Dashboard"
          parent="sunair_crm.menu_crm_application_root"
          action="action_dealer_dashboard"
          sequence="1"/>

</odoo>
