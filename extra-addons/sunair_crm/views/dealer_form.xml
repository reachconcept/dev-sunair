<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════
         Become a Dealer — Main Form Page
    ══════════════════════════════════════════════════════ -->
    <template id="dealer_request_form" name="Become a Dealer">
        <t t-call="website.layout">
            <div class="container py-5">
                <div class="row justify-content-center">
                    <div class="col-lg-8">

                        <h1 class="mb-2">Become A Dealer</h1>
                        <p class="text-muted mb-4">
                            If you are interested in joining the Sunair® dealer network, please fill out
                            the questionnaire below. Once the request is received, our sales department
                            will promptly contact you.
                        </p>

                        <form action="/become-a-dealer/submit" method="post">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                            <!-- ── Contact Information ─────────────────────── -->
                            <h4 class="mt-4 mb-3 border-bottom pb-2">Contact Information</h4>

                            <div class="row g-3">
                                <!-- First Name -->
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold" for="first_name">
                                        First Name <span class="text-danger">*</span>
                                    </label>
                                    <input type="text" id="first_name" name="first_name"
                                           class="form-control"
                                           t-att-class="'is-invalid' if error.get('first_name') else ''"
                                           t-att-value="values.get('first_name', '')"/>
                                    <div class="invalid-feedback">Please provide your first name.</div>
                                </div>

                                <!-- Last Name -->
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold" for="last_name">
                                        Last Name <span class="text-danger">*</span>
                                    </label>
                                    <input type="text" id="last_name" name="last_name"
                                           class="form-control"
                                           t-att-class="'is-invalid' if error.get('last_name') else ''"
                                           t-att-value="values.get('last_name', '')"/>
                                    <div class="invalid-feedback">Please provide your last name.</div>
                                </div>

                                <!-- Title -->
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold" for="title">Title</label>
                                    <input type="text" id="title" name="title"
                                           class="form-control"
                                           t-att-value="values.get('title', '')"/>
                                </div>

                                <!-- Company -->
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold" for="company">Company</label>
                                    <input type="text" id="company" name="company"
                                           class="form-control"
                                           t-att-value="values.get('company', '')"/>
                                </div>

                                <!-- Address -->
                                <div class="col-12">
                                    <label class="form-label fw-semibold" for="street">
                                        Address <span class="text-danger">*</span>
                                    </label>
                                    <input type="text" id="street" name="street"
                                           class="form-control"
                                           t-att-class="'is-invalid' if error.get('street') else ''"
                                           t-att-value="values.get('street', '')"/>
                                    <div class="invalid-feedback">Please provide your address.</div>
                                </div>

                                <!-- City -->
                                <div class="col-md-5">
                                    <label class="form-label fw-semibold" for="city">
                                        City <span class="text-danger">*</span>
                                    </label>
                                    <input type="text" id="city" name="city"
                                           class="form-control"
                                           t-att-class="'is-invalid' if error.get('city') else ''"
                                           t-att-value="values.get('city', '')"/>
                                    <div class="invalid-feedback">Please provide your city.</div>
                                </div>

                                <!-- State -->
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold" for="state_id">
                                        State <span class="text-danger">*</span>
                                    </label>
                                    <select id="state_id" name="state_id"
                                            class="form-select"
                                            t-att-class="'is-invalid' if error.get('state_id') else ''">
                                        <option value="">-- Select State --</option>
                                        <t t-foreach="states" t-as="state">
                                            <option t-att-value="state.id"
                                                    t-att-selected="str(state.id) == str(values.get('state_id', ''))">
                                                <t t-esc="state.name"/>
                                            </option>
                                        </t>
                                    </select>
                                    <div class="invalid-feedback">Please select your state.</div>
                                </div>

                                <!-- Zip -->
                                <div class="col-md-3">
                                    <label class="form-label fw-semibold" for="zip">
                                        Zip Code <span class="text-danger">*</span>
                                    </label>
                                    <input type="text" id="zip" name="zip"
                                           class="form-control"
                                           t-att-class="'is-invalid' if error.get('zip') else ''"
                                           t-att-value="values.get('zip', '')"/>
                                    <div class="invalid-feedback">Please provide your zip code.</div>
                                </div>

                                <!-- Work Phone -->
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold" for="work_phone">Work Phone</label>
                                    <input type="tel" id="work_phone" name="work_phone"
                                           class="form-control"
                                           t-att-value="values.get('work_phone', '')"/>
                                </div>

                                <!-- Email -->
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold" for="email">
                                        Email <span class="text-danger">*</span>
                                    </label>
                                    <input type="email" id="email" name="email"
                                           class="form-control"
                                           t-att-class="'is-invalid' if error.get('email') else ''"
                                           t-att-value="values.get('email', '')"/>
                                    <div class="invalid-feedback">Please provide your email.</div>
                                </div>
                            </div>

                            <!-- ── Business Type ───────────────────────────── -->
                            <h4 class="mt-5 mb-3 border-bottom pb-2">Business Information</h4>

                            <div class="mb-3">
                                <label class="form-label fw-semibold">What type of business are you?</label>
                                <div class="d-flex gap-4">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox"
                                               id="is_distributor" name="is_distributor" value="1"
                                               t-att-checked="values.get('is_distributor')"/>
                                        <label class="form-check-label" for="is_distributor">Distributor</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox"
                                               id="is_retail" name="is_retail" value="1"
                                               t-att-checked="values.get('is_retail')"/>
                                        <label class="form-check-label" for="is_retail">Retail</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox"
                                               id="is_wholesale" name="is_wholesale" value="1"
                                               t-att-checked="values.get('is_wholesale')"/>
                                        <label class="form-check-label" for="is_wholesale">Wholesale</label>
                                    </div>
                                </div>
                            </div>

                            <div class="row g-3">
                                <!-- Years in Business -->
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold" for="years_in_business">
                                        How long have you been in business?
                                    </label>
                                    <input type="text" id="years_in_business" name="years_in_business"
                                           class="form-control"
                                           t-att-value="values.get('years_in_business', '')"/>
                                </div>

                                <!-- Showroom -->
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold" for="has_showroom">
                                        Do you have a showroom?
                                    </label>
                                    <select id="has_showroom" name="has_showroom" class="form-select">
                                        <option value="no"
                                                t-att-selected="values.get('has_showroom', 'no') == 'no'">No</option>
                                        <option value="soon"
                                                t-att-selected="values.get('has_showroom') == 'soon'">No, but will soon</option>
                                        <option value="yes"
                                                t-att-selected="values.get('has_showroom') == 'yes'">Yes</option>
                                    </select>
                                </div>

                                <!-- How heard -->
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold" for="how_heard">
                                        How did you hear about Sunair®?
                                    </label>
                                    <input type="text" id="how_heard" name="how_heard"
                                           class="form-control"
                                           t-att-value="values.get('how_heard', '')"/>
                                </div>

                                <!-- Comments -->
                                <div class="col-12">
                                    <label class="form-label fw-semibold" for="comments">Comments</label>
                                    <textarea id="comments" name="comments" rows="4"
                                              class="form-control"><t t-esc="values.get('comments', '')"/></textarea>
                                </div>
                            </div>

                            <!-- ── Retractable Awnings ─────────────────────── -->
                            <h4 class="mt-5 mb-3 border-bottom pb-2">Retractable Awnings</h4>

                            <div class="mb-3">
                                <label class="form-label fw-semibold">
                                    Do you currently sell retractable awnings?
                                </label>
                                <div class="d-flex gap-3">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio"
                                               name="sells_retractable_awnings" id="ra_no" value="no"
                                               t-att-checked="values.get('sells_retractable_awnings', 'no') == 'no'"/>
                                        <label class="form-check-label" for="ra_no">No</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio"
                                               name="sells_retractable_awnings" id="ra_yes" value="yes"
                                               t-att-checked="values.get('sells_retractable_awnings') == 'yes'"/>
                                        <label class="form-check-label" for="ra_yes">Yes</label>
                                    </div>
                                </div>
                            </div>

                            <div class="row g-3 ms-1 retractable-awnings-details"
                                 id="retractable_awnings_details"
                                 t-att-style="'' if values.get('sells_retractable_awnings') == 'yes' else 'display:none'">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold" for="retractable_awnings_supplier">
                                        If yes, who are you buying from?
                                    </label>
                                    <input type="text" id="retractable_awnings_supplier"
                                           name="retractable_awnings_supplier"
                                           class="form-control"
                                           t-att-value="values.get('retractable_awnings_supplier', '')"/>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold" for="retractable_awnings_sales_pct">
                                        Current percentage of awning sales
                                    </label>
                                    <select id="retractable_awnings_sales_pct"
                                            name="retractable_awnings_sales_pct" class="form-select">
                                        <option value="0_10"   t-att-selected="values.get('retractable_awnings_sales_pct', '0_10') == '0_10'">0% – 10%</option>
                                        <option value="11_25"  t-att-selected="values.get('retractable_awnings_sales_pct') == '11_25'">10% – 25%</option>
                                        <option value="26_50"  t-att-selected="values.get('retractable_awnings_sales_pct') == '26_50'">25% – 50%</option>
                                        <option value="51_75"  t-att-selected="values.get('retractable_awnings_sales_pct') == '51_75'">50% – 75%</option>
                                        <option value="76_100" t-att-selected="values.get('retractable_awnings_sales_pct') == '76_100'">75% – 100%</option>
                                    </select>
                                </div>
                            </div>

                            <!-- ── Solar Screens ───────────────────────────── -->
                            <h4 class="mt-5 mb-3 border-bottom pb-2">Solar Screens</h4>

                            <div class="mb-3">
                                <label class="form-label fw-semibold">
                                    Do you currently sell solar screens?
                                </label>
                                <div class="d-flex gap-3">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio"
                                               name="sells_solar_screens" id="ss_no" value="no"
                                               t-att-checked="values.get('sells_solar_screens', 'no') == 'no'"/>
                                        <label class="form-check-label" for="ss_no">No</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio"
                                               name="sells_solar_screens" id="ss_yes" value="yes"
                                               t-att-checked="values.get('sells_solar_screens') == 'yes'"/>
                                        <label class="form-check-label" for="ss_yes">Yes</label>
                                    </div>
                                </div>
                            </div>

                            <div class="row g-3 ms-1"
                                 id="solar_screens_details"
                                 t-att-style="'' if values.get('sells_solar_screens') == 'yes' else 'display:none'">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold" for="solar_screens_supplier">
                                        If yes, who are you buying from?
                                    </label>
                                    <input type="text" id="solar_screens_supplier"
                                           name="solar_screens_supplier"
                                           class="form-control"
                                           t-att-value="values.get('solar_screens_supplier', '')"/>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold" for="solar_screens_sales_pct">
                                        Current percentage of solar screen sales
                                    </label>
                                    <select id="solar_screens_sales_pct"
                                            name="solar_screens_sales_pct" class="form-select">
                                        <option value="0_10"   t-att-selected="values.get('solar_screens_sales_pct', '0_10') == '0_10'">0% – 10%</option>
                                        <option value="11_25"  t-att-selected="values.get('solar_screens_sales_pct') == '11_25'">10% – 25%</option>
                                        <option value="26_50"  t-att-selected="values.get('solar_screens_sales_pct') == '26_50'">25% – 50%</option>
                                        <option value="51_75"  t-att-selected="values.get('solar_screens_sales_pct') == '51_75'">50% – 75%</option>
                                        <option value="76_100" t-att-selected="values.get('solar_screens_sales_pct') == '76_100'">75% – 100%</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold" for="solar_screens_type">
                                        If yes, what type?
                                    </label>
                                    <select id="solar_screens_type" name="solar_screens_type" class="form-select">
                                        <option value="exterior" t-att-selected="values.get('solar_screens_type', 'exterior') == 'exterior'">Exterior</option>
                                        <option value="interior" t-att-selected="values.get('solar_screens_type') == 'interior'">Interior</option>
                                        <option value="both"     t-att-selected="values.get('solar_screens_type') == 'both'">Both</option>
                                    </select>
                                </div>
                            </div>

                            <!-- ── Pergola / Louvered Systems ─────────────── -->
                            <h4 class="mt-5 mb-3 border-bottom pb-2">Pergola® / Adjustable Louvered Systems</h4>

                            <div class="mb-3">
                                <label class="form-label fw-semibold">
                                    Do you currently sell Pergola® Awnings or Adjustable Louvered Systems?
                                </label>
                                <div class="d-flex gap-3">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio"
                                               name="sells_pergola_louvered" id="pl_no" value="no"
                                               t-att-checked="values.get('sells_pergola_louvered', 'no') == 'no'"/>
                                        <label class="form-check-label" for="pl_no">No</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio"
                                               name="sells_pergola_louvered" id="pl_yes" value="yes"
                                               t-att-checked="values.get('sells_pergola_louvered') == 'yes'"/>
                                        <label class="form-check-label" for="pl_yes">Yes</label>
                                    </div>
                                </div>
                            </div>

                            <div class="row g-3 ms-1"
                                 id="pergola_details"
                                 t-att-style="'' if values.get('sells_pergola_louvered') == 'yes' else 'display:none'">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold" for="pergola_louvered_supplier">
                                        If yes, who are you buying from?
                                    </label>
                                    <input type="text" id="pergola_louvered_supplier"
                                           name="pergola_louvered_supplier"
                                           class="form-control"
                                           t-att-value="values.get('pergola_louvered_supplier', '')"/>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold" for="pergola_louvered_sales_pct">
                                        Current percentage of Pergola® / Louvered Systems sales
                                    </label>
                                    <select id="pergola_louvered_sales_pct"
                                            name="pergola_louvered_sales_pct" class="form-select">
                                        <option value="0_10"   t-att-selected="values.get('pergola_louvered_sales_pct', '0_10') == '0_10'">0% – 10%</option>
                                        <option value="11_25"  t-att-selected="values.get('pergola_louvered_sales_pct') == '11_25'">10% – 25%</option>
                                        <option value="26_50"  t-att-selected="values.get('pergola_louvered_sales_pct') == '26_50'">25% – 50%</option>
                                        <option value="51_75"  t-att-selected="values.get('pergola_louvered_sales_pct') == '51_75'">50% – 75%</option>
                                        <option value="76_100" t-att-selected="values.get('pergola_louvered_sales_pct') == '76_100'">75% – 100%</option>
                                    </select>
                                </div>
                            </div>

                            <!-- ── Submit ──────────────────────────────────── -->
                            <div class="mt-5 d-flex justify-content-end">
                                <button type="submit" class="btn btn-primary btn-lg px-5">
                                    Submit Request
                                </button>
                            </div>

                        </form>

                    </div>
                </div>
            </div>

            <!-- Toggle JS for conditional sections -->
            <script>
                document.addEventListener('DOMContentLoaded', function () {
                    function toggleSection(radioName, sectionId) {
                        const radios = document.querySelectorAll('input[name="' + radioName + '"]');
                        const section = document.getElementById(sectionId);
                        function update() {
                            const checked = document.querySelector('input[name="' + radioName + '"]:checked');
                            section.style.display = (checked &amp;&amp; checked.value === 'yes') ? '' : 'none';
                        }
                        radios.forEach(r => r.addEventListener('change', update));
                        update();
                    }
                    toggleSection('sells_retractable_awnings', 'retractable_awnings_details');
                    toggleSection('sells_solar_screens',       'solar_screens_details');
                    toggleSection('sells_pergola_louvered',    'pergola_details');
                });
            </script>
        </t>
    </template>

    <!-- ══════════════════════════════════════════════════════
         Thank-you page after successful submission
    ══════════════════════════════════════════════════════ -->
    <template id="dealer_request_success" name="Dealer Request — Success">
        <t t-call="website.layout">
            <div class="container py-5 text-center">
                <div class="row justify-content-center">
                    <div class="col-lg-6">
                        <i class="fa fa-check-circle fa-4x text-success mb-4"/>
                        <h2 class="mb-3">Thank You!</h2>
                        <p class="lead text-muted">
                            Your dealer request has been submitted. Our sales department will
                            contact you shortly.
                        </p>
                        <a href="/" class="btn btn-outline-primary mt-3">Back to Home</a>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>