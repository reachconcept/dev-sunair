        <!-- ── Toggle JS ──────────────────────────────── -->
        <script>
            (function() {
                function toggle(radioName, sectionId) {
                    var radios  = document.querySelectorAll('input[name="' + radioName + '"]');
                    var section = document.getElementById(sectionId);
                    function upd() {
                        var checked = document.querySelector('input[name="' + radioName + '"]:checked');
                        section.style.display = (checked &amp;&amp; checked.value === 'yes') ? '' : 'none';
                    }
                    radios.forEach(function(r){ r.addEventListener('change', upd); });
                    upd();
                }
                toggle('sells_retractable_awnings', 'ra_details');
                toggle('sells_solar_screens',       'ss_details');
                toggle('sells_pergola_louvered',    'pl_details');

                /* Yes/No pill active state via JS for older browsers */
                document.querySelectorAll('.dr-yn label').forEach(function(lbl) {
                    lbl.addEventListener('click', function() {
                        var name = lbl.querySelector('input').name;
                        document.querySelectorAll('.dr-yn label input[name="' + name + '"]').forEach(function(r){
                            r.closest('label').style.background = '';
                            r.closest('label').style.color = '';
                            r.closest('label').style.borderColor = '';
                        });
                        lbl.style.background   = 'var(--sun-dark)';
                        lbl.style.color        = 'var(--sun-white)';
                        lbl.style.borderColor  = 'var(--sun-dark)';
                    });
                });
                /* Init pill states on page load */
                document.querySelectorAll('.dr-yn input[type="radio"]:checked').forEach(function(r){
                    var lbl = r.closest('label');
                    lbl.style.background  = 'var(--sun-dark)';
                    lbl.style.color       = 'var(--sun-white)';
                    lbl.style.borderColor = 'var(--sun-dark)';
                });
            })();
        </script>

    </t>
</template>

