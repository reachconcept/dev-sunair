<?xml version="1.0" encoding="utf-8"?>
<odoo >

    <!-- Email to the dealer when a lead is assigned to them -->
    <record id="email_template_dealer_lead_assigned" model="mail.template">
        <field name="name"> </field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="subject">New Lead Assigned to You: {{ object.name }}</field>
        <field name="email_from">{{ object.company_id.email or user.email }}</field>
        <field name="email_to">{{ object.dealer_id.email }}</field>
        <field name="body_html" type="html">
            <div style="font-family: Arial, sans-serif; font-size: 14px; color: #333; max-width: 600px; margin: 0 auto;">

                <div style="background-color: #2c5364; padding: 24px 32px; border-radius: 8px 8px 0 0;">
                    <h2 style="color: #ffffff; margin: 0; font-size: 20px;">New Lead Assigned to You</h2>
                    <p style="color: rgba(255,255,255,0.75); margin: 6px 0 0 0; font-size: 13px;">Sunair Shades — Dealer Portal</p>
                </div>

                <div style="background-color: #f9f9f9; padding: 28px 32px; border: 1px solid #e5e5e5; border-top: none; border-radius: 0 0 8px 8px;">

                    <p style="margin-top: 0;">Dear <strong><t t-out="object.dealer_id.name or 'Dealer'"/></strong>,</p>

                    <p>A new sales lead has been assigned to you. Please review the details below and reach out to the prospect at your earliest convenience.</p>

                    <table style="width: 100%; border-collapse: collapse; margin: 20px 0; font-size: 13px;">
                        <tr style="background-color: #f0f4ff;">
                            <td style="padding: 10px 14px; font-weight: 600; color: #1e1b4b; width: 35%; border-bottom: 1px solid #e0e0e0;">Lead</td>
                            <td style="padding: 10px 14px; border-bottom: 1px solid #e0e0e0;"><t t-out="object.name"/></td>
                        </tr>
                        <tr>
                            <td style="padding: 10px 14px; font-weight: 600; color: #1e1b4b; border-bottom: 1px solid #e0e0e0;">Contact Name</td>
                            <td style="padding: 10px 14px; border-bottom: 1px solid #e0e0e0;"><t t-out="object.contact_name or object.partner_name or '—'"/></td>
                        </tr>
                        <tr style="background-color: #f0f4ff;">
                            <td style="padding: 10px 14px; font-weight: 600; color: #1e1b4b; border-bottom: 1px solid #e0e0e0;">Email</td>
                            <td style="padding: 10px 14px; border-bottom: 1px solid #e0e0e0;"><t t-out="object.email_from or '—'"/></td>
                        </tr>
                        <tr>
                            <td style="padding: 10px 14px; font-weight: 600; color: #1e1b4b; border-bottom: 1px solid #e0e0e0;">Phone</td>
                            <td style="padding: 10px 14px; border-bottom: 1px solid #e0e0e0;"><t t-out="object.phone or '—'"/></td>
                        </tr>
                        <tr style="background-color: #f0f4ff;">
                            <td style="padding: 10px 14px; font-weight: 600; color: #1e1b4b; border-bottom: 1px solid #e0e0e0;">Location</td>
                            <td style="padding: 10px 14px; border-bottom: 1px solid #e0e0e0;"><t t-out="(object.city or '') + (', ' + object.state_id.name if object.state_id else '') + (' ' + object.zip if object.zip else '') or '—'"/></td>
                        </tr>
                        <tr>
                            <td style="padding: 10px 14px; font-weight: 600; color: #1e1b4b; border-bottom: 1px solid #e0e0e0;">Territory</td>
                            <td style="padding: 10px 14px; border-bottom: 1px solid #e0e0e0;"><t t-out="object.territory_id.name or '—'"/></td>
                        </tr>
                        <tr style="background-color: #f0f4ff;">
                            <td style="padding: 10px 14px; font-weight: 600; color: #1e1b4b;">Notes</td>
                            <td style="padding: 10px 14px;"><t t-out="object.description or '—'"/></td>
                        </tr>
                    </table>

                    <p>Please make contact with this prospect as soon as possible. If you have any questions or need assistance, do not hesitate to contact your Sunair representative.</p>

                    <p style="margin-bottom: 0;">Best regards,<br/><strong>Sunair Shades Team</strong></p>

                </div>

                <p style="font-size: 11px; color: #aaa; text-align: center; margin-top: 16px;">
                    This is an automated message from Sunair Shades. Please do not reply directly to this email.
                </p>

            </div>
        </field>
        <field name="lang">{{ object.dealer_id.lang }}</field>
        <field name="auto_delete" eval="True"/>
    </record>

    <!-- Email to the lead contact when a dealer has been assigned -->
    <record id="email_template_lead_dealer_assigned" model="mail.template">
        <field name="name">Dealer Assigned — Notification to Lead</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="subject">Great News — A Sunair Dealer Has Been Assigned to You</field>
        <field name="email_from">{{ object.company_id.email or user.email }}</field>
        <field name="email_to">{{ object.email_from }}</field>
        <field name="body_html" type="html">
            <div style="font-family: Arial, sans-serif; font-size: 14px; color: #333; max-width: 600px; margin: 0 auto;">

                <div style="background-color: #20c997; padding: 24px 32px; border-radius: 8px 8px 0 0;">
                    <h2 style="color: #ffffff; margin: 0; font-size: 20px;">A Dealer Has Been Assigned to You</h2>
                    <p style="color: rgba(255,255,255,0.85); margin: 6px 0 0 0; font-size: 13px;">Sunair Shades — Your Inquiry Update</p>
                </div>

                <div style="background-color: #f9f9f9; padding: 28px 32px; border: 1px solid #e5e5e5; border-top: none; border-radius: 0 0 8px 8px;">

                    <p style="margin-top: 0;">Dear <strong><t t-out="object.contact_name or object.partner_name or 'Valued Customer'"/></strong>,</p>

                    <p>Thank you for your interest in Sunair Shades products. We are pleased to let you know that a certified Sunair dealer in your area has been assigned to assist you.</p>

                    <div style="background-color: #f0fdf9; border: 1px solid #a7f3d0; border-radius: 8px; padding: 18px 22px; margin: 20px 0;">
                        <p style="margin: 0 0 6px 0; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: #065f46;">Your Assigned Dealer</p>
                        <p style="margin: 0; font-size: 16px; font-weight: 700; color: #1e1b4b;"><t t-out="object.dealer_id.name or '—'"/></p>
                        <t t-if="object.dealer_id.phone or object.dealer_id.email">
                            <p style="margin: 8px 0 0 0; font-size: 13px; color: #374151;">
                                <t t-if="object.dealer_id.phone">📞 <t t-out="object.dealer_id.phone"/><br/></t>
                                <t t-if="object.dealer_id.email">✉️ <t t-out="object.dealer_id.email"/></t>
                            </p>
                        </t>
                    </div>

                    <p>Your dealer will be in touch with you shortly to discuss your requirements and guide you through our product range. You can also reach out to them directly using the contact details above.</p>

                    <p>We look forward to helping you find the perfect Sunair solution.</p>

                    <p style="margin-bottom: 0;">Warm regards,<br/><strong>Sunair Shades Team</strong></p>

                </div>

                <p style="font-size: 11px; color: #aaa; text-align: center; margin-top: 16px;">
                    This is an automated message from Sunair Shades. Please do not reply directly to this email.
                </p>

            </div>
        </field>
        <field name="lang">{{ object.partner_id.lang }}</field>
        <field name="auto_delete" eval="True"/>
    </record>

    <record id="dealer_application_invite_email" model="mail.template">
        <field name="name">Dealer Application Invitation</field>
        <field name="model_id" ref="model_dealer_application"/>
        <field name="subject">You're Invited to Apply — Sunair Dealer Program</field>
        <field name="email_from">{{ object.company_id.email or user.email }}</field>
        <field name="email_to">{{ object.partner_id.email }}</field>
        <field name="body_html" type="html">
            <div style="font-family: Arial, sans-serif; font-size: 14px; color: #333333; max-width: 600px; margin: 0 auto; background-color: #f4f4f7; padding: 24px; border-radius: 12px;">
                <div style="background-color: #ffffff; border-radius: 12px; border: 1px solid #e8e6f0; overflow: hidden;">
                
                    <!-- Header -->
                    <div style="background-color: #1a1a2e; padding: 28px 32px;">
                    <table width="100%" cellpadding="0" cellspacing="0">
                        <tr>
                        <td style="vertical-align: middle;">
                            <table cellpadding="0" cellspacing="0">
                            <tr>
                                <td style="vertical-align: middle; padding-right: 14px;">
                                <div style="width: 44px; height: 44px; border-radius: 50%; background-color: #c9a227; text-align: center; line-height: 44px; font-size: 20px;">&#9728;</div>
                                </td>
                                <td style="vertical-align: middle;">
                                <p style="color: #ffffff; font-size: 17px; font-weight: bold; margin: 0;">Sunair Architectural Structures</p>
                                <p style="color: rgba(255,255,255,0.5); font-size: 11px; margin: 3px 0 0; text-transform: uppercase; letter-spacing: 1px;">Dealer application invitation</p>
                                </td>
                            </tr>
                            </table>
                        </td>
                        </tr>
                    </table>
                    </div>
                
                    <!-- Gold stripe -->
                    <div style="height: 3px; background-color: #c9a227;"></div>
                
                    <!-- Body -->
                    <div style="padding: 28px 32px;">
                
                    <p style="font-size: 15px; font-weight: bold; color: #1a1a2e; margin: 0 0 18px;">
                        Dear <t t-out="object.partner_id.name or 'Valued Partner'"/>,
                    </p>
                
                    <p style="font-size: 14px; color: #555555; line-height: 1.7; margin: 0 0 14px;">
                        Thank you for your interest in becoming a dealer with <strong style="color: #1a1a2e;">Sunair Architectural Structures</strong>. We're excited about the possibility of welcoming you to our dealer network.
                    </p>
                
                    <p style="font-size: 14px; color: #555555; line-height: 1.7; margin: 0 0 24px;">
                        To proceed, please complete your dealer application using the button below. The form will only take a few minutes and our team will review your submission promptly.
                    </p>
                
                    <!-- Info card -->
                    <div style="background-color: #f4f4f7; border-radius: 8px; padding: 16px 18px; margin-bottom: 26px;">
                        <table width="100%" cellpadding="0" cellspacing="0">
                        <tr>
                            <td style="width: 36px; vertical-align: top; padding-top: 2px;">
                            <div style="width: 24px; height: 24px; border-radius: 50%; background-color: #c9a227; text-align: center; line-height: 24px; font-size: 13px; font-weight: bold; color: #1a1a2e;">i</div>
                            </td>
                            <td style="vertical-align: top;">
                            <p style="font-size: 13px; color: #555555; margin: 0; line-height: 1.6;">
                                This invitation was created for <strong style="color: #1a1a2e;"><t t-out="object.partner_id.name or '—'"/></strong>.
                                <t t-if="object.company_legal_name">
                                Your application is linked to <strong style="color: #1a1a2e;"><t t-out="object.company_legal_name"/></strong>.
                                </t>
                            </p>
                            </td>
                        </tr>
                        </table>
                    </div>
                
                    <!-- CTA button -->
                    <div style="text-align: center; margin-bottom: 28px;">
                        <a t-att-href="'/my/dealer-applications'" style="display: inline-block; background-color: #1a1a2e; color: #c9a227; font-size: 14px; font-weight: bold; padding: 13px 32px; border-radius: 8px; text-decoration: none; letter-spacing: 0.3px;">
                        Complete Your Application
                        </a>
                    </div>
                
                    <p style="font-size: 13px; color: #888888; line-height: 1.6; margin: 0 0 18px;">
                        If you have any questions before or during the application process, don't hesitate to reach out to your Sunair contact directly.
                    </p>
                
                    <p style="font-size: 14px; color: #333333; margin: 0;">
                        Warm regards,<br/>
                        <strong style="color: #1a1a2e;">Sunair Team</strong>
                    </p>
                
                    </div>
                
                    <!-- Footer -->
                    <div style="border-top: 1px solid #e8e6f0; padding: 14px 32px;">
                    <table width="100%" cellpadding="0" cellspacing="0">
                        <tr>
                        <td style="font-size: 11px; color: #cccccc;">Sunair Architectural Structures</td>
                        <td style="font-size: 11px; color: #cccccc; text-align: right;">Automated notification — do not reply</td>
                        </tr>
                    </table>
                    </div>
                
                </div>
            </div>
        </field>
        <field name="lang">{{ object.partner_id.lang }}</field>
        <field name="auto_delete" eval="True"/>
    </record>

     <record id="email_template_dealer_request_notify_company" model="mail.template">
        <field name="name">Dealer Request — Notify Company</field>
        <field name="model_id" ref="model_dealer_request"/>
        <field name="subject">New Dealer Request Received: {{ object.name }}</field>
        <field name="email_to">{{ object.company_id.email }}</field>
        <field name="email_from">{{ object.company_id.email}},{{ object.email }}</field>
        <field name="body_html" type="html">
            <div style="font-family: Arial, sans-serif; font-size: 14px; color: #333333; max-width: 600px; margin: 0 auto; background-color: #f4f4f7; padding: 24px; border-radius: 12px;">
                <div style="background-color: #ffffff; border-radius: 12px; border: 1px solid #e8e6f0; overflow: hidden;">
                
                    <!-- Header -->
                    <div style="background-color: #1a1a2e; padding: 24px 28px;">
                    <table width="100%" cellpadding="0" cellspacing="0">
                        <tr>
                        <td style="vertical-align: middle;">
                            <table cellpadding="0" cellspacing="0">
                            <tr>
                                <td style="vertical-align: middle; padding-right: 14px;">
                                <div style="width: 44px; height: 44px; border-radius: 50%; background-color: #c9a227; text-align: center; line-height: 44px; font-size: 20px;">&#9728;</div>
                                </td>
                                <td style="vertical-align: middle;">
                                <p style="color: #ffffff; font-size: 17px; font-weight: bold; margin: 0;">Sunair Architectural Structures</p>
                                <p style="color: rgba(255,255,255,0.5); font-size: 11px; margin: 3px 0 0; text-transform: uppercase; letter-spacing: 1px;">New dealer application received</p>
                                </td>
                            </tr>
                            </table>
                        </td>
                        <td style="text-align: right; vertical-align: middle;">
                            <span style="font-size: 12px; font-weight: bold; color: #1a1a2e; background-color: #c9a227; padding: 4px 12px; border-radius: 20px;">
                            <t t-out="object.name or '—'"/>
                            </span>
                        </td>
                        </tr>
                    </table>
                    </div>
                
                    <!-- Gold stripe -->
                    <div style="height: 3px; background-color: #c9a227;"></div>
                
                    <!-- Body -->
                    <div style="padding: 24px 28px;">
                
                    <p style="font-size: 15px; font-weight: bold; color: #1a1a2e; margin: 0 0 22px;">A new dealer application has been submitted and requires your review.</p>
                
                    <!-- 2x2 stat grid -->
                    <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 20px;">
                        <tr>
                        <td width="50%" style="padding-right: 6px; padding-bottom: 12px; vertical-align: top;">
                            <div style="background-color: #f4f4f7; border-radius: 8px; padding: 12px 14px;">
                            <p style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.8px; color: #aaaaaa; margin: 0 0 4px;">Applicant</p>
                            <p style="font-size: 14px; font-weight: bold; color: #1a1a2e; margin: 0;">
                                <t t-out="(object.first_name or '') + ' ' + (object.last_name or '')"/>
                            </p>
                            </div>
                        </td>
                        <td width="50%" style="padding-left: 6px; padding-bottom: 12px; vertical-align: top;">
                            <div style="background-color: #f4f4f7; border-radius: 8px; padding: 12px 14px;">
                            <p style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.8px; color: #aaaaaa; margin: 0 0 4px;">Company</p>
                            <p style="font-size: 14px; font-weight: bold; color: #1a1a2e; margin: 0;">
                                <t t-out="object.company or object.company_legal_name or '—'"/>
                            </p>
                            </div>
                        </td>
                        </tr>
                        <tr>
                        <td width="50%" style="padding-right: 6px; vertical-align: top;">
                            <div style="background-color: #f4f4f7; border-radius: 8px; padding: 12px 14px;">
                            <p style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.8px; color: #aaaaaa; margin: 0 0 4px;">Location</p>
                            <p style="font-size: 14px; font-weight: bold; color: #1a1a2e; margin: 0;">
                                <t t-out="(object.city or '') + (', ' + object.country_state_id.name if object.country_state_id else '') + (' ' + object.zip if object.zip else '') or '—'"/>
                            </p>
                            </div>
                        </td>
                        <td width="50%" style="padding-left: 6px; vertical-align: top;">
                            <div style="background-color: #f4f4f7; border-radius: 8px; padding: 12px 14px;">
                            <p style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.8px; color: #aaaaaa; margin: 0 0 4px;">Years in business</p>
                            <p style="font-size: 14px; font-weight: bold; color: #1a1a2e; margin: 0;">
                                <t t-out="object.years_in_business or '—'"/>
                            </p>
                            </div>
                        </td>
                        </tr>
                    </table>
                
                    <!-- Contact details -->
                    <table width="100%" cellpadding="0" cellspacing="0" style="border: 1px solid #e8e6f0; border-radius: 8px; overflow: hidden; margin-bottom: 20px;">
                        <tr>
                        <td colspan="2" style="background-color: #f4f4f7; padding: 9px 14px; border-bottom: 1px solid #e8e6f0;">
                            <p style="font-size: 11px; font-weight: bold; color: #888888; margin: 0; text-transform: uppercase; letter-spacing: 0.6px;">Contact details</p>
                        </td>
                        </tr>
                        <tr>
                        <td style="padding: 9px 14px; font-size: 13px; color: #888888; border-bottom: 1px solid #e8e6f0; width: 130px;">Email</td>
                        <td style="padding: 9px 14px; font-size: 13px; color: #1a1a2e; border-bottom: 1px solid #e8e6f0;"><t t-out="object.email or '—'"/></td>
                        </tr>
                        <tr>
                        <td style="padding: 9px 14px; font-size: 13px; color: #888888; border-bottom: 1px solid #e8e6f0; width: 130px;">Phone</td>
                        <td style="padding: 9px 14px; font-size: 13px; color: #1a1a2e; border-bottom: 1px solid #e8e6f0;"><t t-out="object.work_phone or '—'"/></td>
                        </tr>
                        <tr>
                        <td style="padding: 9px 14px; font-size: 13px; color: #888888; width: 130px;">Has showroom</td>
                        <td style="padding: 9px 14px; font-size: 13px; color: #1a1a2e;">
                            <t t-if="object.has_showroom == 'yes'">Yes</t>
                            <t t-else="">No</t>
                        </td>
                        </tr>
                    </table>
                
                    <!-- Product interests -->
                    <table width="100%" cellpadding="0" cellspacing="0" style="border: 1px solid #e8e6f0; border-radius: 8px; overflow: hidden; margin-bottom: 20px;">
                        <tr>
                        <td style="background-color: #f4f4f7; padding: 9px 14px; border-bottom: 1px solid #e8e6f0;">
                            <p style="font-size: 11px; font-weight: bold; color: #888888; margin: 0; text-transform: uppercase; letter-spacing: 0.6px;">Product interests</p>
                        </td>
                        </tr>
                        <tr>
                        <td style="padding: 12px 14px;">
                            <t t-if="object.sells_retractable_awnings == 'yes'">
                            <span style="font-size: 12px; font-weight: bold; color: #c9a227; background-color: #1a1a2e; padding: 4px 12px; border-radius: 20px; display: inline-block; margin: 3px 4px 3px 0;">Retractable Awnings</span>
                            </t>
                            <t t-if="object.sells_solar_screens == 'yes'">
                            <span style="font-size: 12px; font-weight: bold; color: #c9a227; background-color: #1a1a2e; padding: 4px 12px; border-radius: 20px; display: inline-block; margin: 3px 4px 3px 0;">Solar Screens</span>
                            </t>
                            <t t-if="object.sells_pergola_louvered == 'yes'">
                            <span style="font-size: 12px; font-weight: bold; color: #c9a227; background-color: #1a1a2e; padding: 4px 12px; border-radius: 20px; display: inline-block; margin: 3px 4px 3px 0;">Pergola / Louvered</span>
                            </t>
                            <t t-if="object.is_distributor">
                            <span style="font-size: 12px; font-weight: bold; color: #c9a227; background-color: #1a1a2e; padding: 4px 12px; border-radius: 20px; display: inline-block; margin: 3px 4px 3px 0;">Distributor</span>
                            </t>
                            <t t-if="object.is_retail">
                            <span style="font-size: 12px; font-weight: bold; color: #c9a227; background-color: #1a1a2e; padding: 4px 12px; border-radius: 20px; display: inline-block; margin: 3px 4px 3px 0;">Retail</span>
                            </t>
                            <t t-if="object.is_wholesale">
                            <span style="font-size: 12px; font-weight: bold; color: #c9a227; background-color: #1a1a2e; padding: 4px 12px; border-radius: 20px; display: inline-block; margin: 3px 4px 3px 0;">Wholesale</span>
                            </t>
                        </td>
                        </tr>
                    </table>
                
                    <!-- Comments -->
                    <t t-if="object.comments">
                        <div style="background-color: #f4f4f7; border-radius: 8px; padding: 14px 16px; margin-bottom: 22px;">
                        <p style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.8px; color: #aaaaaa; margin: 0 0 6px;">Comments</p>
                        <p style="font-size: 13px; color: #333333; margin: 0; line-height: 1.6;"><t t-out="object.comments"/></p>
                        </div>
                    </t>
                
                    <!-- How heard -->
                    <t t-if="object.how_heard">
                        <div style="background-color: #f4f4f7; border-radius: 8px; padding: 14px 16px; margin-bottom: 22px;">
                        <p style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.8px; color: #aaaaaa; margin: 0 0 6px;">How did they hear about us</p>
                        <p style="font-size: 13px; color: #333333; margin: 0;"><t t-out="object.how_heard"/></p>
                        </div>
                    </t>
                
                    <!-- CTA button -->
                    <div style="text-align: center; margin-top: 4px;">
                        <a t-att-href="'/odoo/dealer-applications/' + str(object.id)" style="display: inline-block; background-color: #1a1a2e; color: #c9a227; font-size: 14px; font-weight: bold; padding: 13px 28px; border-radius: 8px; text-decoration: none; letter-spacing: 0.3px;">
                        Review application in Odoo
                        </a>
                    </div>
                
                    </div>
                
                    <!-- Footer -->
                    <div style="border-top: 1px solid #e8e6f0; padding: 14px 28px;">
                    <table width="100%" cellpadding="0" cellspacing="0">
                        <tr>
                        <td style="font-size: 11px; color: #cccccc;">Sunair Architectural Structures</td>
                        <td style="font-size: 11px; color: #cccccc; text-align: right;">Automated notification — do not reply</td>
                        </tr>
                    </table>
                    </div>
                
                </div>
            </div>
        </field>
        <field name="auto_delete" eval="True"/>
    </record>
</odoo>